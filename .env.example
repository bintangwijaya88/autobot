# ==============================
# API
# ==============================
APP_PORT=50080
APP_ENV=production

# Database (MySQL — host machine, pakai host.docker.internal dari dalam container)
DB_DRIVER=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=autobot
DB_USER=autobot
DB_PASSWORD=changeme
DB_SSL_MODE=disable

# Redis (opsional)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=changeme-jwt-secret
JWT_EXPIRY=24h

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# CORS
CORS_ORIGINS=https://autobot.co.id

# Rate Limit
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# Admin credentials
ADMIN_EMAIL=admin@autobot.co.id
ADMIN_PASSWORD=changeme

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_ENV=sandbox

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Autobot <noreply@autobot.co.id>
SMTP_DEBUG=false
SMTP_TEST_TO=

# Google OAuth
GOOGLE_CLIENT_ID=

# ==============================
# Web (Nuxt)
# ==============================
NUXT_PUBLIC_API_BASE=https://api.autobot.co.id
NUXT_PUBLIC_WS_URL=wss://api.autobot.co.id/ws
NUXT_PUBLIC_GOOGLE_CLIENT_ID=

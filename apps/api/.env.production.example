# ─── Server ─────────────────────────────────────────────────
APP_PORT=3000
APP_ENV=production

# ─── Database (MySQL) ────────────────────────────────────────
DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_NAME=autobot
DB_USER=autobot
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM
JWT_EXPIRY=24h

# ─── AI Provider (openai | anthropic) ───────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-REPLACE_WITH_REAL_KEY
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-REPLACE_IF_USING
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=https://autobot.co.id,https://www.autobot.co.id

# ─── Rate Limit ──────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# ─── Admin ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@autobot.co.id
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ─── SMTP (for OTP emails) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=autobotwsolution@gmail.com
SMTP_PASS=GMAIL_APP_PASSWORD
SMTP_FROM=Autobot <noreply@autobot.co.id>
SMTP_DEBUG=false

# ─── Midtrans ────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=REPLACE_IF_USING
MIDTRANS_ENV=production

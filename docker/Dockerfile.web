FROM node:20-alpine AS builder

WORKDIR /app
COPY apps/web/package*.json ./
RUN npm ci

COPY apps/web/ .
RUN npm run build

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app/.output .output
COPY --from=builder /app/package.json .

EXPOSE 3001
ENV HOST=0.0.0.0
ENV PORT=3001
CMD ["node", ".output/server/index.mjs"]
